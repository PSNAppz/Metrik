{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Metrik",
  "version": "0.1.0",
  "identifier": "com.metrik.panel",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Metrik",
        "width": 800,
        "height": 480,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "fullscreen": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
